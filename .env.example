APP_NAME="Gestor de Leads do WhatsApp"
DEBUG="true"

# ============================================================================
# Database Configuration
# ============================================================================
# Unified database with separate schemas for each service
DATABASE_URL="postgresql+asyncpg://postgres:postgres@db:5432/gestor_leads"
EVOLUTION_DATABASE_CONNECTION_URI="postgresql://postgres:postgres@db:5432/gestor_leads?schema=evolution_api"
LITELLM_DATABASE_URL="postgresql://postgres:postgres@db:5432/gestor_leads?schema=litellm"

# ============================================================================
# JWT & Authentication
# ============================================================================
# SECURITY: use a strong secret from a secrets manager (no hardcoded value in production)
SECRET_KEY="change-me"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24h

# ============================================================================
# LLM Configuration
# ============================================================================
# LiteLLM Gateway (Docker): http://litellm:4000/v1
# LLM_API_BASE="http://litellm:4000/v1"
LLM_API_BASE="http://ollama:11434"
LLM_API_KEY="dev-litellm-key"
# LLM_MODEL="lead-analysis-primary"
LLM_MODEL="ollama/llama3.2:1b"
OPENAI_API_KEY=
ANALYSIS_RATE_LIMIT=30
ANALYSIS_RATE_LIMIT_WINDOW_SECONDS=60
ANALYSIS_MAX_CONTEXT_MESSAGES=20
ANALYSIS_MAX_OUTPUT_TOKENS=512
ANALYSIS_WORKER_CONCURRENCY=1
ANALYSIS_JSON_PARSE_RETRIES=2

# ============================================================================
# WhatsApp Provider Selection
# ============================================================================
# Options: "evolution" (default) | "waha"
WHATSAPP_PROVIDER="evolution"

# ============================================================================
# WAHA Provider Configuration (only if WHATSAPP_PROVIDER="waha")
# ============================================================================
# WAHA_API_URL="http://waha:3000"
# WAHA_API_PORT=3000
# WAHA_API_KEY=

# ============================================================================
# Evolution Provider Configuration (only if WHATSAPP_PROVIDER="evolution")
# ============================================================================
# Official docs: https://docs.evolutionfoundation.com.br/evolution-api/index.md
# LLM-friendly docs index: https://docs.evolutionfoundation.com.br/llms.txt
EVOLUTION_API_URL="http://evolution-api:8080"
EVOLUTION_API_KEY=change-me

# ============================================================================
# Webhook Configuration (shared across all providers)
# ============================================================================
# URL where our backend receives webhook events
# NOTE: Inside Docker, use "backend" as hostname, not "localhost"
WEBHOOK_URL="http://backend:8000/webhooks/whatsapp"
# SECURITY: store webhook secrets in a secrets manager (Docker secrets, Vault, cloud secret manager)
WEBHOOK_HMAC_SECRET=

# ============================================================================
# Webhook Security & Rate Limiting
# ============================================================================
WEBHOOK_REPLAY_TTL_SECONDS=300
WEBHOOK_REQUIRE_REPLAY_HEADERS="false"
WEBHOOK_MAX_PAYLOAD_BYTES=3000000 # 3MB
WEBHOOK_RATE_LIMIT=300
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# Authentication Security
# ============================================================================
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL="INFO"
LOG_JSON="true"

# ============================================================================
# Security Headers (CSP, HSTS, etc)
# ============================================================================
# prod
# SECURITY_CSP="default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"
#     default-src 'none' -> bloque todas as fontes por padrão, permitindo apenas as explicitamente listadas
#     frame-ancestors 'none' -> impede que a aplicação seja embutida em iframes, prevenindo ataques de clickjacking
#     base-uri 'none' -> bloqueia a capacidade de definir uma URL base para a aplicação, prevenindo ataques de URL spoofing
#     form-action 'none' -> bloqueia o envio de formulários para URLs não autorizadas, prevenindo ataques de CSRF
# dev
SECURITY_CSP=""
SECURITY_REFERRER_POLICY="no-referrer"
SECURITY_PERMISSIONS_POLICY="camera=(), microphone=(), geolocation=()"
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS="true"
SECURITY_HSTS_PRELOAD="false"

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGINS='["http://localhost:3000"]'
