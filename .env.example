APP_NAME="Gestor de Leads do WhatsApp"
DEBUG="true"

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@db:5432/leads"

# JWT
# SECURITY: use a strong secret from a secrets manager (no hardcoded value in production)
SECRET_KEY="change-me"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24h

# LLM
LLM_API_KEY=
LLM_MODEL="gpt-4o-mini"

# WhatsApp
WHATSAPP_API_URL="http://waha:3000"
WHATSAPP_API_PORT=3000
WHATSAPP_API_KEY=
WHATSAPP_PROVIDER="waha"
WHATSAPP_WEBHOOK_URL="http://localhost:8000/webhooks/whatsapp"
# SECURITY: store webhook secrets in a secrets manager (Docker secrets, Vault, cloud secret manager)
WHATSAPP_WEBHOOK_HMAC_KEY=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_REPLAY_TTL_SECONDS=300
WHATSAPP_WEBHOOK_REQUIRE_REPLAY_HEADERS="false"
WHATSAPP_WEBHOOK_MAX_PAYLOAD_BYTES=262144
WHATSAPP_WEBHOOK_RATE_LIMIT=300
WHATSAPP_WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60

# Auth hardening
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Security headers
SECURITY_CSP="default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"
SECURITY_REFERRER_POLICY="no-referrer"
SECURITY_PERMISSIONS_POLICY="camera=(), microphone=(), geolocation=()"
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS="true"
SECURITY_HSTS_PRELOAD="false"

# CORS
CORS_ORIGINS=["http://localhost:3000"]
